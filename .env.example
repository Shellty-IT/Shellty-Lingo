# Local infrastructure only. Copy to .env; never commit real values.
POSTGRES_DB=shellty_lingo
POSTGRES_USER=shellty
POSTGRES_PASSWORD=local_shellty_password
POSTGRES_PORT=5432

# AI conversation + translation providers (free tiers, fallback chain).
# Leave keys empty to run on the deterministic fallback only — the app never blocks.
# Order is tried left-to-right; a provider without a key is skipped.
AI_PROVIDER_ORDER=gemini,groq
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
AI_REQUEST_TIMEOUT_MS=20000
AI_MAX_RETRIES=1
AI_DAILY_BUDGET_USD=8
AI_TRANSLATION_ENABLED=true
