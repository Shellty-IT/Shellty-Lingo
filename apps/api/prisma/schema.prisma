generator client {
  provider = "prisma-client"
  output = "../src/generated/prisma"
  moduleFormat = "cjs"
}
datasource db {
 provider = "postgresql"
}
enum UserRole {
 learner
 editor
 admin
}
enum OneTimeTokenPurpose {
 email_verification
 password_reset
}
enum RequestStatus {
 pending
 processing
 completed
 cancelled
}
model SystemMetadata {
 id String @id @default(uuid()) @db.Uuid
 key String @unique @db.VarChar(100)
 value String @db.VarChar(500)
 createdAt DateTime @default(now()) @map("created_at")
 updatedAt DateTime @updatedAt @map("updated_at")
 @@map("system_metadata")
}
model User {
 id String @id @default(uuid()) @db.Uuid
 email String @unique @db.VarChar(320)
 passwordHash String @map("password_hash")
 emailVerifiedAt DateTime? @map("email_verified_at")
 role UserRole @default(learner)
 createdAt DateTime @default(now()) @map("created_at")
 updatedAt DateTime @updatedAt @map("updated_at")
 profile UserProfile?
 sessions RefreshToken[]
 courses UserCourse[]
 consents Consent[]
 oneTimeTokens OneTimeToken[]
 exports DataExportRequest[]
 deletions AccountDeletionRequest[]
 auditLogs AuditLog[]
 @@map("users")
}
model UserProfile {
 userId String @id @map("user_id") @db.Uuid
 displayName String? @map("display_name") @db.VarChar(100)
 interfaceLocale String @default("pl") @map("interface_locale") @db.VarChar(10)
 notificationsEnabled Boolean @default(false) @map("notifications_enabled")
 onboardingCompletedAt DateTime? @map("onboarding_completed_at")
 user User @relation(fields: [userId], references: [id], onDelete: Cascade)
 @@map("user_profiles")
}
model UserCourse {
 id String @id @default(uuid()) @db.Uuid
 userId String @map("user_id") @db.Uuid
 language String @db.VarChar(10)
 learningGoal String @map("learning_goal") @db.VarChar(50)
 dailyMinutes Int @default(15) @map("daily_minutes")
 thaiTransliterationEnabled Boolean @default(true) @map("thai_transliteration_enabled")
 createdAt DateTime @default(now()) @map("created_at")
 user User @relation(fields: [userId], references: [id], onDelete: Cascade)
 @@unique([userId, language])
 @@map("user_courses")
}
model RefreshToken {
 id String @id @default(uuid()) @db.Uuid
 userId String @map("user_id") @db.Uuid
 familyId String @map("family_id") @db.Uuid
 tokenHash String @unique @map("token_hash") @db.VarChar(128)
 expiresAt DateTime @map("expires_at")
 revokedAt DateTime? @map("revoked_at")
 replacedById String? @unique @map("replaced_by_id") @db.Uuid
 createdAt DateTime @default(now()) @map("created_at")
 user User @relation(fields: [userId], references: [id], onDelete: Cascade)
 @@index([userId, familyId])
 @@map("refresh_tokens")
}
model OneTimeToken {
 id String @id @default(uuid()) @db.Uuid
 userId String @map("user_id") @db.Uuid
 purpose OneTimeTokenPurpose
 tokenHash String @unique @map("token_hash") @db.VarChar(128)
 expiresAt DateTime @map("expires_at")
 usedAt DateTime? @map("used_at")
 user User @relation(fields: [userId], references: [id], onDelete: Cascade)
 @@map("one_time_tokens")
}
model Consent {
 id String @id @default(uuid()) @db.Uuid
 userId String @map("user_id") @db.Uuid
 key String @db.VarChar(80)
 granted Boolean
 version String @db.VarChar(30)
 createdAt DateTime @default(now()) @map("created_at")
 user User @relation(fields: [userId], references: [id], onDelete: Cascade)
 @@index([userId, key])
 @@map("consents")
}
model DataExportRequest {
 id String @id @default(uuid()) @db.Uuid
 userId String @map("user_id") @db.Uuid
 status RequestStatus @default(pending)
 createdAt DateTime @default(now()) @map("created_at")
 user User @relation(fields: [userId], references: [id], onDelete: Cascade)
 @@map("data_export_requests")
}
model AccountDeletionRequest {
 id String @id @default(uuid()) @db.Uuid
 userId String @map("user_id") @db.Uuid
 status RequestStatus @default(pending)
 scheduledFor DateTime @map("scheduled_for")
 createdAt DateTime @default(now()) @map("created_at")
 user User @relation(fields: [userId], references: [id], onDelete: Cascade)
 @@map("account_deletion_requests")
}
model AuditLog {
 id String @id @default(uuid()) @db.Uuid
 userId String? @map("user_id") @db.Uuid
 event String @db.VarChar(100)
 ipHash String? @map("ip_hash") @db.VarChar(128)
 createdAt DateTime @default(now()) @map("created_at")
 user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
 @@index([userId, event])
 @@map("audit_logs")
}
