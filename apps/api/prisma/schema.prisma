generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  learner
  editor
  admin
}

enum OneTimeTokenPurpose {
  email_verification
  password_reset
}

enum RequestStatus {
  pending
  processing
  completed
  cancelled
}

enum ContentStatus {
  draft
  review
  published
  archived
}

enum ExerciseType {
  single_choice
  multiple_choice
  matching
  gap_fill
  typed_answer
  ordering
  listening
}

enum MediaKind {
  audio
  illustration
}

enum LearningSessionKind {
  placement
  lesson
  review
}

enum LearningSessionStatus {
  active
  completed
  abandoned
}

enum ReviewRating {
  again
  hard
  good
  easy
}

enum ThaiUnitKind {
  consonant
  vowel
  syllable
  digit
  tone_rule
}

enum ConversationStatus {
  active
  completed
  blocked
}

enum ConversationRole {
  learner
  assistant
}

enum NotificationKind {
  learning_reminder
  review_due
  product_updates
}

enum NotificationDeliveryStatus {
  queued
  sent
  failed
  suppressed
}

enum BillingStore {
  apple
  google
}

enum SubscriptionStatus {
  active
  grace_period
  expired
  refunded
  cancelled
}

enum BillingEventStatus {
  received
  processed
  rejected
}

enum SupportTicketStatus {
  open
  in_review
  resolved
}

model SystemMetadata {
  id        String   @id @default(uuid()) @db.Uuid
  key       String   @unique @db.VarChar(100)
  value     String   @db.VarChar(500)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("system_metadata")
}

model User {
  id                        String                   @id @default(uuid()) @db.Uuid
  email                     String                   @unique @db.VarChar(320)
  passwordHash              String                   @map("password_hash")
  emailVerifiedAt           DateTime?                @map("email_verified_at")
  role                      UserRole                 @default(learner)
  createdAt                 DateTime                 @default(now()) @map("created_at")
  updatedAt                 DateTime                 @updatedAt @map("updated_at")
  profile                   UserProfile?
  sessions                  RefreshToken[]
  courses                   UserCourse[]
  consents                  Consent[]
  oneTimeTokens             OneTimeToken[]
  exports                   DataExportRequest[]
  deletions                 AccountDeletionRequest[]
  auditLogs                 AuditLog[]
  contentRevisionsReviewed  ContentRevision[]        @relation("revision_reviewer")
  contentRevisionsPublished ContentRevision[]        @relation("revision_publisher")
  contentAuditEntries       ContentAuditEntry[]
  learningEvents            LearningEvent[]
  conversationReports       ConversationReport[]
  notificationPreferences   NotificationPreference[]
  notificationDeliveries    NotificationDelivery[]
  subscriptions             Subscription[]
  entitlements              Entitlement[]
  supportTickets            SupportTicket[]

  @@map("users")
}

model Course {
  id             String          @id @default(uuid()) @db.Uuid
  slug           String          @unique @db.VarChar(100)
  language       String          @db.VarChar(10)
  level          String          @db.VarChar(20)
  title          String          @db.VarChar(200)
  description    String?         @db.Text
  status         ContentStatus   @default(draft)
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")
  modules        CourseModule[]
  learningEvents LearningEvent[]

  @@index([language, status])
  @@map("courses")
}

model CourseModule {
  id       String        @id @default(uuid()) @db.Uuid
  courseId String        @map("course_id") @db.Uuid
  slug     String        @db.VarChar(100)
  title    String        @db.VarChar(200)
  position Int
  status   ContentStatus @default(draft)
  course   Course        @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons  Lesson[]

  @@unique([courseId, slug])
  @@unique([courseId, position])
  @@map("course_modules")
}

model Lesson {
  id                  String            @id @default(uuid()) @db.Uuid
  moduleId            String            @map("module_id") @db.Uuid
  slug                String            @db.VarChar(100)
  position            Int
  status              ContentStatus     @default(draft)
  publishedRevisionId String?           @unique @map("published_revision_id") @db.Uuid
  createdAt           DateTime          @default(now()) @map("created_at")
  updatedAt           DateTime          @updatedAt @map("updated_at")
  premium             Boolean           @default(false)
  module              CourseModule      @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  revisions           ContentRevision[]
  publishedRevision   ContentRevision?  @relation("published_revision", fields: [publishedRevisionId], references: [id], onDelete: SetNull)
  learningSessions    LearningSession[]
  progress            LessonProgress[]

  @@unique([moduleId, slug])
  @@unique([moduleId, position])
  @@map("lessons")
}

model ContentRevision {
  id               String             @id @default(uuid()) @db.Uuid
  lessonId         String             @map("lesson_id") @db.Uuid
  version          Int
  status           ContentStatus      @default(draft)
  title            String             @db.VarChar(200)
  summary          String?            @db.Text
  estimatedMinutes Int                @map("estimated_minutes")
  completeness     Json               @default("{}")
  reviewNote       String?            @map("review_note") @db.Text
  reviewedAt       DateTime?          @map("reviewed_at")
  reviewedById     String?            @map("reviewed_by_id") @db.Uuid
  publishedAt      DateTime?          @map("published_at")
  publishedById    String?            @map("published_by_id") @db.Uuid
  createdAt        DateTime           @default(now()) @map("created_at")
  lesson           Lesson             @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  publishedFor     Lesson?            @relation("published_revision")
  reviewedBy       User?              @relation("revision_reviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  publishedBy      User?              @relation("revision_publisher", fields: [publishedById], references: [id], onDelete: SetNull)
  exercises        Exercise[]
  vocabularyLinks  LessonVocabulary[]
  grammarLinks     LessonGrammar[]

  @@unique([lessonId, version])
  @@index([status])
  @@map("content_revisions")
}

model Exercise {
  id           String            @id @default(uuid()) @db.Uuid
  revisionId   String            @map("revision_id") @db.Uuid
  position     Int
  type         ExerciseType
  prompt       String            @db.Text
  instructions String?           @db.Text
  options      Json?
  answer       Json
  explanation  String?           @db.Text
  mediaAssetId String?           @map("media_asset_id") @db.Uuid
  revision     ContentRevision   @relation(fields: [revisionId], references: [id], onDelete: Cascade)
  mediaAsset   MediaAsset?       @relation(fields: [mediaAssetId], references: [id], onDelete: SetNull)
  attempts     ExerciseAttempt[]

  @@unique([revisionId, position])
  @@map("exercises")
}

model VocabularyEntry {
  id              String                 @id @default(uuid()) @db.Uuid
  language        String                 @db.VarChar(10)
  term            String                 @db.VarChar(300)
  partOfSpeech    String?                @map("part_of_speech") @db.VarChar(50)
  definition      String                 @db.Text
  transliteration String?                @db.VarChar(500)
  toneMarks       String?                @map("tone_marks") @db.VarChar(500)
  createdAt       DateTime               @default(now()) @map("created_at")
  pronunciations  PronunciationVariant[]
  lessonLinks     LessonVocabulary[]
  reviewItems     ReviewItem[]

  @@unique([language, term])
  @@map("vocabulary_entries")
}

model PronunciationVariant {
  id              String          @id @default(uuid()) @db.Uuid
  vocabularyId    String          @map("vocabulary_id") @db.Uuid
  label           String?         @db.VarChar(100)
  ipa             String?         @db.VarChar(500)
  transliteration String?         @db.VarChar(500)
  toneMarks       String?         @map("tone_marks") @db.VarChar(500)
  audioAssetId    String?         @map("audio_asset_id") @db.Uuid
  vocabulary      VocabularyEntry @relation(fields: [vocabularyId], references: [id], onDelete: Cascade)
  audioAsset      MediaAsset?     @relation(fields: [audioAssetId], references: [id], onDelete: SetNull)

  @@map("pronunciation_variants")
}

model GrammarTopic {
  id          String          @id @default(uuid()) @db.Uuid
  language    String          @db.VarChar(10)
  slug        String          @db.VarChar(100)
  title       String          @db.VarChar(200)
  explanation String          @db.Text
  lessonLinks LessonGrammar[]

  @@unique([language, slug])
  @@map("grammar_topics")
}

model LessonVocabulary {
  revisionId   String          @map("revision_id") @db.Uuid
  vocabularyId String          @map("vocabulary_id") @db.Uuid
  revision     ContentRevision @relation(fields: [revisionId], references: [id], onDelete: Cascade)
  vocabulary   VocabularyEntry @relation(fields: [vocabularyId], references: [id], onDelete: Cascade)

  @@id([revisionId, vocabularyId])
  @@map("lesson_vocabulary")
}

model LessonGrammar {
  revisionId String          @map("revision_id") @db.Uuid
  grammarId  String          @map("grammar_id") @db.Uuid
  revision   ContentRevision @relation(fields: [revisionId], references: [id], onDelete: Cascade)
  grammar    GrammarTopic    @relation(fields: [grammarId], references: [id], onDelete: Cascade)

  @@id([revisionId, grammarId])
  @@map("lesson_grammar")
}

model Translation {
  id         String    @id @default(uuid()) @db.Uuid
  entityType String    @map("entity_type") @db.VarChar(50)
  entityId   String    @map("entity_id") @db.Uuid
  locale     String    @db.VarChar(10)
  field      String    @db.VarChar(100)
  value      String    @db.Text
  verifiedAt DateTime? @map("verified_at")

  @@unique([entityType, entityId, locale, field])
  @@map("translations")
}

model MediaAsset {
  id             String                 @id @default(uuid()) @db.Uuid
  kind           MediaKind
  storageKey     String                 @unique @map("storage_key") @db.VarChar(500)
  contentType    String                 @map("content_type") @db.VarChar(100)
  byteSize       Int                    @map("byte_size")
  durationMs     Int?                   @map("duration_ms")
  altText        String?                @map("alt_text") @db.Text
  createdAt      DateTime               @default(now()) @map("created_at")
  exercises      Exercise[]
  pronunciations PronunciationVariant[]

  @@map("media_assets")
}

model ContentAuditEntry {
  id           String   @id @default(uuid()) @db.Uuid
  actorId      String?  @map("actor_id") @db.Uuid
  action       String   @db.VarChar(100)
  resourceType String   @map("resource_type") @db.VarChar(50)
  resourceId   String   @map("resource_id") @db.Uuid
  metadata     Json     @default("{}")
  createdAt    DateTime @default(now()) @map("created_at")
  actor        User?    @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([resourceType, resourceId])
  @@map("content_audit_entries")
}

model UserProfile {
  userId                String    @id @map("user_id") @db.Uuid
  displayName           String?   @map("display_name") @db.VarChar(100)
  interfaceLocale       String    @default("pl") @map("interface_locale") @db.VarChar(10)
  notificationsEnabled  Boolean   @default(false) @map("notifications_enabled")
  onboardingCompletedAt DateTime? @map("onboarding_completed_at")
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

model UserCourse {
  id                         String            @id @default(uuid()) @db.Uuid
  userId                     String            @map("user_id") @db.Uuid
  language                   String            @db.VarChar(10)
  learningGoal               String            @map("learning_goal") @db.VarChar(50)
  dailyMinutes               Int               @default(15) @map("daily_minutes")
  thaiTransliterationEnabled Boolean           @default(true) @map("thai_transliteration_enabled")
  currentLevel               String            @default("A1") @map("current_level") @db.VarChar(20)
  placementScore             Int?              @map("placement_score")
  placementCompletedAt       DateTime?         @map("placement_completed_at")
  createdAt                  DateTime          @default(now()) @map("created_at")
  user                       User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  learningSessions           LearningSession[]
  lessonProgress             LessonProgress[]
  reviewItems                ReviewItem[]
  learningEvents             LearningEvent[]
  conversations              AiConversation[]

  @@unique([userId, language])
  @@map("user_courses")
}

model LearningSession {
  id                String                @id @default(uuid()) @db.Uuid
  userCourseId      String                @map("user_course_id") @db.Uuid
  lessonId          String?               @map("lesson_id") @db.Uuid
  kind              LearningSessionKind
  status            LearningSessionStatus @default(active)
  idempotencyKey    String                @map("idempotency_key") @db.VarChar(100)
  currentExerciseId String?               @map("current_exercise_id") @db.Uuid
  correctCount      Int                   @default(0) @map("correct_count")
  totalCount        Int                   @default(0) @map("total_count")
  result            Json                  @default("{}")
  startedAt         DateTime              @default(now()) @map("started_at")
  lastActivityAt    DateTime              @default(now()) @map("last_activity_at")
  completedAt       DateTime?             @map("completed_at")
  userCourse        UserCourse            @relation(fields: [userCourseId], references: [id], onDelete: Cascade)
  lesson            Lesson?               @relation(fields: [lessonId], references: [id], onDelete: SetNull)
  attempts          ExerciseAttempt[]
  placementAnswers  PlacementAnswer[]

  @@unique([userCourseId, idempotencyKey])
  @@index([userCourseId, status, lastActivityAt])
  @@map("learning_sessions")
}

model ExerciseAttempt {
  id             String          @id @default(uuid()) @db.Uuid
  sessionId      String          @map("session_id") @db.Uuid
  exerciseId     String          @map("exercise_id") @db.Uuid
  idempotencyKey String          @map("idempotency_key") @db.VarChar(100)
  answer         Json
  correct        Boolean
  score          Float
  feedback       Json            @default("{}")
  answeredAt     DateTime        @default(now()) @map("answered_at")
  session        LearningSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  exercise       Exercise        @relation(fields: [exerciseId], references: [id], onDelete: Restrict)

  @@unique([sessionId, idempotencyKey])
  @@index([exerciseId, answeredAt])
  @@map("exercise_attempts")
}

model PlacementAnswer {
  id               String          @id @default(uuid()) @db.Uuid
  sessionId        String          @map("session_id") @db.Uuid
  questionId       String          @map("question_id") @db.VarChar(80)
  selectedOptionId String          @map("selected_option_id") @db.VarChar(80)
  correct          Boolean
  session          LearningSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, questionId])
  @@map("placement_answers")
}

model LessonProgress {
  id             String     @id @default(uuid()) @db.Uuid
  userCourseId   String     @map("user_course_id") @db.Uuid
  lessonId       String     @map("lesson_id") @db.Uuid
  status         String     @default("not_started") @db.VarChar(30)
  attempts       Int        @default(0)
  bestScore      Float      @default(0) @map("best_score")
  lastExerciseId String?    @map("last_exercise_id") @db.Uuid
  completedAt    DateTime?  @map("completed_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")
  userCourse     UserCourse @relation(fields: [userCourseId], references: [id], onDelete: Cascade)
  lesson         Lesson     @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userCourseId, lessonId])
  @@index([userCourseId, status])
  @@map("lesson_progress")
}

model ReviewItem {
  id              String           @id @default(uuid()) @db.Uuid
  userCourseId    String           @map("user_course_id") @db.Uuid
  vocabularyId    String?          @map("vocabulary_id") @db.Uuid
  sourceKey       String           @map("source_key") @db.VarChar(500)
  sourceText      String           @map("source_text") @db.Text
  translation     String           @db.Text
  context         String?          @db.Text
  intervalMinutes Int              @default(0) @map("interval_minutes")
  easeFactor      Float            @default(2.5) @map("ease_factor")
  repetitions     Int              @default(0)
  lapses          Int              @default(0)
  dueAt           DateTime         @default(now()) @map("due_at")
  lastReviewedAt  DateTime?        @map("last_reviewed_at")
  createdAt       DateTime         @default(now()) @map("created_at")
  userCourse      UserCourse       @relation(fields: [userCourseId], references: [id], onDelete: Cascade)
  vocabulary      VocabularyEntry? @relation(fields: [vocabularyId], references: [id], onDelete: SetNull)
  attempts        ReviewAttempt[]

  @@unique([userCourseId, sourceKey])
  @@index([userCourseId, dueAt])
  @@map("review_items")
}

model ReviewAttempt {
  id             String       @id @default(uuid()) @db.Uuid
  reviewItemId   String       @map("review_item_id") @db.Uuid
  idempotencyKey String       @map("idempotency_key") @db.VarChar(100)
  rating         ReviewRating
  previousDueAt  DateTime     @map("previous_due_at")
  nextDueAt      DateTime     @map("next_due_at")
  reviewedAt     DateTime     @default(now()) @map("reviewed_at")
  reviewItem     ReviewItem   @relation(fields: [reviewItemId], references: [id], onDelete: Cascade)

  @@unique([reviewItemId, idempotencyKey])
  @@map("review_attempts")
}

model LearningEvent {
  id           String      @id @default(uuid()) @db.Uuid
  userId       String      @map("user_id") @db.Uuid
  userCourseId String?     @map("user_course_id") @db.Uuid
  courseId     String?     @map("course_id") @db.Uuid
  name         String      @db.VarChar(100)
  properties   Json        @default("{}")
  createdAt    DateTime    @default(now()) @map("created_at")
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  userCourse   UserCourse? @relation(fields: [userCourseId], references: [id], onDelete: SetNull)
  course       Course?     @relation(fields: [courseId], references: [id], onDelete: SetNull)

  @@index([userId, name, createdAt])
  @@map("learning_events")
}

model ThaiScriptUnit {
  id              String       @id @default(uuid()) @db.Uuid
  kind            ThaiUnitKind
  glyph           String       @db.VarChar(30)
  name            String       @db.VarChar(120)
  transliteration String       @db.VarChar(120)
  meaning         String       @db.VarChar(200)
  toneClass       String?      @map("tone_class") @db.VarChar(20)
  tone            String?      @db.VarChar(20)
  audioUrl        String?      @map("audio_url") @db.Text
  example         Json
  position        Int
  expertReviewed  Boolean      @default(false) @map("expert_reviewed")
  published       Boolean      @default(false)

  @@unique([kind, glyph])
  @@index([published, position])
  @@map("thai_script_units")
}

model AiPromptVersion {
  id            String           @id @default(uuid()) @db.Uuid
  key           String           @db.VarChar(80)
  version       Int
  systemPrompt  String           @map("system_prompt") @db.Text
  responseSchema Json            @map("response_schema")
  active        Boolean          @default(false)
  createdAt     DateTime         @default(now()) @map("created_at")
  conversations AiConversation[]

  @@unique([key, version])
  @@index([key, active])
  @@map("ai_prompt_versions")
}

model AiConversation {
  id                String             @id @default(uuid()) @db.Uuid
  userCourseId      String             @map("user_course_id") @db.Uuid
  promptVersionId   String             @map("prompt_version_id") @db.Uuid
  scenarioId        String             @map("scenario_id") @db.VarChar(80)
  correctionMode    String             @map("correction_mode") @db.VarChar(40)
  level             String             @db.VarChar(20)
  status            ConversationStatus @default(active)
  messageLimit      Int                @default(12) @map("message_limit")
  inputTokens       Int                @default(0) @map("input_tokens")
  outputTokens      Int                @default(0) @map("output_tokens")
  estimatedCostUsd  Decimal            @default(0) @map("estimated_cost_usd") @db.Decimal(10, 6)
  summary           Json?
  startedAt         DateTime           @default(now()) @map("started_at")
  completedAt       DateTime?          @map("completed_at")
  userCourse        UserCourse         @relation(fields: [userCourseId], references: [id], onDelete: Cascade)
  promptVersion     AiPromptVersion    @relation(fields: [promptVersionId], references: [id], onDelete: Restrict)
  messages          AiConversationMessage[]
  reports           ConversationReport[]

  @@index([userCourseId, status, startedAt])
  @@map("ai_conversations")
}

model AiConversationMessage {
  id             String           @id @default(uuid()) @db.Uuid
  conversationId String           @map("conversation_id") @db.Uuid
  role           ConversationRole
  text           String           @db.Text
  correction     Json?
  moderation     Json             @default("{}")
  inputTokens    Int              @default(0) @map("input_tokens")
  outputTokens   Int              @default(0) @map("output_tokens")
  createdAt      DateTime         @default(now()) @map("created_at")
  conversation   AiConversation   @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@map("ai_conversation_messages")
}

model ConversationReport {
  id             String         @id @default(uuid()) @db.Uuid
  conversationId String         @map("conversation_id") @db.Uuid
  reporterId     String         @map("reporter_id") @db.Uuid
  reason         String         @db.VarChar(80)
  details        String?        @db.Text
  status         RequestStatus  @default(pending)
  createdAt      DateTime       @default(now()) @map("created_at")
  conversation   AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  reporter       User           @relation(fields: [reporterId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
  @@map("conversation_reports")
}

model RefreshToken {
  id           String    @id @default(uuid()) @db.Uuid
  userId       String    @map("user_id") @db.Uuid
  familyId     String    @map("family_id") @db.Uuid
  tokenHash    String    @unique @map("token_hash") @db.VarChar(128)
  expiresAt    DateTime  @map("expires_at")
  revokedAt    DateTime? @map("revoked_at")
  replacedById String?   @unique @map("replaced_by_id") @db.Uuid
  createdAt    DateTime  @default(now()) @map("created_at")
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, familyId])
  @@map("refresh_tokens")
}

model OneTimeToken {
  id        String              @id @default(uuid()) @db.Uuid
  userId    String              @map("user_id") @db.Uuid
  purpose   OneTimeTokenPurpose
  tokenHash String              @unique @map("token_hash") @db.VarChar(128)
  expiresAt DateTime            @map("expires_at")
  usedAt    DateTime?           @map("used_at")
  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("one_time_tokens")
}

model Consent {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  key       String   @db.VarChar(80)
  granted   Boolean
  version   String   @db.VarChar(30)
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key, version])
  @@map("consents")
}

model DataExportRequest {
  id        String        @id @default(uuid()) @db.Uuid
  userId    String        @map("user_id") @db.Uuid
  status    RequestStatus @default(pending)
  createdAt DateTime      @default(now()) @map("created_at")
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("data_export_requests")
}

model AccountDeletionRequest {
  id           String        @id @default(uuid()) @db.Uuid
  userId       String        @map("user_id") @db.Uuid
  status       RequestStatus @default(pending)
  scheduledFor DateTime      @map("scheduled_for")
  createdAt    DateTime      @default(now()) @map("created_at")
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("account_deletion_requests")
}

model AuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String?  @map("user_id") @db.Uuid
  event     String   @db.VarChar(100)
  ipHash    String?  @map("ip_hash") @db.VarChar(128)
  createdAt DateTime @default(now()) @map("created_at")
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, event])
  @@map("audit_logs")
}

model NotificationPreference {
  id              String           @id @default(uuid()) @db.Uuid
  userId          String           @map("user_id") @db.Uuid
  kind            NotificationKind
  enabled         Boolean          @default(false)
  localTime       String           @default("19:00") @map("local_time") @db.VarChar(5)
  timezone        String           @default("UTC") @db.VarChar(100)
  quietHoursStart String           @default("22:00") @map("quiet_hours_start") @db.VarChar(5)
  quietHoursEnd   String           @default("07:00") @map("quiet_hours_end") @db.VarChar(5)
  updatedAt       DateTime         @updatedAt @map("updated_at")
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  deliveries      NotificationDelivery[]

  @@unique([userId, kind])
  @@index([enabled, kind])
  @@map("notification_preferences")
}

model NotificationDelivery {
  id             String                     @id @default(uuid()) @db.Uuid
  userId         String                     @map("user_id") @db.Uuid
  preferenceId   String                     @map("preference_id") @db.Uuid
  idempotencyKey String                     @unique @map("idempotency_key") @db.VarChar(160)
  status         NotificationDeliveryStatus @default(queued)
  scheduledAt    DateTime                   @map("scheduled_at")
  sentAt         DateTime?                  @map("sent_at")
  failureCode    String?                    @map("failure_code") @db.VarChar(80)
  createdAt      DateTime                   @default(now()) @map("created_at")
  user           User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  preference     NotificationPreference     @relation(fields: [preferenceId], references: [id], onDelete: Cascade)

  @@index([status, scheduledAt])
  @@map("notification_deliveries")
}

model Subscription {
  id                    String             @id @default(uuid()) @db.Uuid
  userId                String             @map("user_id") @db.Uuid
  store                 BillingStore
  productId             String             @map("product_id") @db.VarChar(120)
  originalTransactionId String             @map("original_transaction_id") @db.VarChar(200)
  status                SubscriptionStatus
  currentPeriodEnd      DateTime           @map("current_period_end")
  autoRenewing          Boolean            @default(true) @map("auto_renewing")
  environment           String             @default("sandbox") @db.VarChar(20)
  createdAt             DateTime           @default(now()) @map("created_at")
  updatedAt             DateTime           @updatedAt @map("updated_at")
  user                  User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([store, originalTransactionId])
  @@index([userId, status, currentPeriodEnd])
  @@map("subscriptions")
}

model Entitlement {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  key       String    @db.VarChar(80)
  active    Boolean   @default(false)
  expiresAt DateTime? @map("expires_at")
  source    String    @db.VarChar(40)
  updatedAt DateTime  @updatedAt @map("updated_at")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
  @@index([key, active])
  @@map("entitlements")
}

model BillingEvent {
  id          String             @id @default(uuid()) @db.Uuid
  store       BillingStore
  externalId  String             @map("external_id") @db.VarChar(200)
  eventType   String             @map("event_type") @db.VarChar(80)
  payloadHash String             @map("payload_hash") @db.VarChar(128)
  status      BillingEventStatus @default(received)
  processedAt DateTime?          @map("processed_at")
  createdAt   DateTime           @default(now()) @map("created_at")

  @@unique([store, externalId])
  @@index([status, createdAt])
  @@map("billing_events")
}

model SupportTicket {
  id        String              @id @default(uuid()) @db.Uuid
  userId    String              @map("user_id") @db.Uuid
  category  String              @db.VarChar(50)
  subject   String              @db.VarChar(160)
  message   String              @db.Text
  status    SupportTicketStatus @default(open)
  createdAt DateTime            @default(now()) @map("created_at")
  updatedAt DateTime            @updatedAt @map("updated_at")
  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
  @@map("support_tickets")
}
