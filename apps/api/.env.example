NODE_ENV=development
APP_ENV=development
API_HOST=0.0.0.0
API_PORT=3001
CORS_ORIGINS=http://localhost:3002,http://localhost:8081
APP_VERSION=development
DATABASE_URL=postgresql://shellty:local_shellty_password@localhost:5432/shellty_lingo?schema=public
LOG_LEVEL=debug
# Optional. Keep empty locally; configure through the deployment secret store.
SENTRY_DSN=
AUTH_ACCESS_TOKEN_SECRET=replace_with_at_least_32_random_characters
AUTH_REFRESH_TOKEN_SECRET=replace_with_at_least_32_random_characters
AUTH_ACCESS_TOKEN_TTL_SECONDS=900
AUTH_REFRESH_TOKEN_TTL_DAYS=30
BILLING_WEBHOOK_SECRET=replace_with_at_least_32_random_characters
BILLING_SANDBOX_ENABLED=true
