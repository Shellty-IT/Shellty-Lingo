{
  "expo": {
    "name": "Shellty Lingo",
    "slug": "shellty-lingo",
    "owner": "shellty-it",
    "version": "1.0.0",
    "icon": "./assets/icon.png",
    "orientation": "default",
    "scheme": "shelltylingo",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "pl.shellty.lingo"
    },
    "android": {
      "package": "pl.shellty.lingo",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0B1A30"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-localization",
      "@sentry/react-native/expo",
      [
        "expo-audio",
        {
          "microphonePermission": "Pozwól Shellty Lingo nagrać Twoją lokalną próbę wymowy. Nagranie nie opuszcza urządzenia.",
          "enableBackgroundRecording": false,
          "enableBackgroundPlayback": false
        }
      ],
      "expo-font",
      "expo-secure-store",
      "expo-splash-screen",
      "expo-status-bar"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "3c373187-65e9-4c17-906c-ba06bd562ee8"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/3c373187-65e9-4c17-906c-ba06bd562ee8"
    }
  }
}
