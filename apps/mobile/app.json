{
  "expo": {
    "name": "Shellty Lingo",
    "slug": "shellty-lingo",
    "version": "1.0.0",
    "icon": "./assets/icon.png",
    "orientation": "default",
    "scheme": "shelltylingo",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "pl.shellty.lingo"
    },
    "android": {
      "package": "pl.shellty.lingo",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0B1A30"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-localization",
      "@sentry/react-native/expo",
      [
        "expo-audio",
        {
          "microphonePermission": "Pozwól Shellty Lingo nagrać Twoją lokalną próbę wymowy. Nagranie nie opuszcza urządzenia.",
          "enableBackgroundRecording": false,
          "enableBackgroundPlayback": false
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
